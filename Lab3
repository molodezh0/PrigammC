#include <stdio.h>

int main() {

    char str[81];

    printf("Enter a string of up to 80 characters:\n");
    gets_s(str, 81);

    for (int i = 0; str[i] != '\0'; i++) {


        if (str[i] == 'a') {
            str[i] = 'A';
        }

        else if (str[i] == 'b') {
            str[i] = 'B';
        }
    }

    printf("Modified string:\n%s", str);

    return 0;
}
