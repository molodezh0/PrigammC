#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>
#include <stdlib.h>
#include "matrix.h"
int main() {
    int n;
    printf("Enter matrix size: ");
    scanf("%d", &n);
    double** mat1 = create_mat(n);
    double** mat2 = create_mat(n);
    double** res;
    printf("Input first matrix:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%lf", &mat1[i][j]);
        }
    }
    printf("Input second matrix:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%lf", &mat2[i][j]);
        }
    }
    char op;
    printf("Action (+, -, *): ");
    scanf(" %c", &op);
    if (op == '+') {
        res = sum_mat(mat1, mat2, n);
    }
    else if (op == '-') {
        res = sub_mat(mat1, mat2, n);
    }
    else if (op == '*') {
        res = mul_mat(mat1, mat2, n);
    }
    else {
        printf("Unknown action!\n");
        return 1;
    }
    printf("Result:\n");
    for (int j = 0; j < n; j++) {
        for (int i = 0; i < n; i++) {
            printf("%lf\n", res[i][j]);
        }
    }
    return 0;
}
