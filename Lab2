#include <stdio.h>


int main(int argc, char* argv[]) {
int N = 4;
 double arr[N][N];
 double FirstSum = 0.0;
 double SecondSum = 0.0;
 int i, j;
 printf("Enter the elements of the NxN matrix (%d numbers separated by spaces): \n", N * N);
 for ( i = 0; i < N; i++) {
  for ( j = 0; j < N; j++) {
   scanf_s("%lf", &arr[i][j]);

  }
 }

printf("\n Matrix arr:\n");
for ( i = 0; i < N; i++) {
  for ( j = 0; j < N; j++) {
   printf("%6.2lf", arr[i][j]);
  }
  printf("\n");
}
printf("\n");
   


 for (i = 0; i < N; i++) {

  FirstSum += arr[i][i];

  SecondSum += arr[i][N - 1 - i];

 }
 printf("Sum of the main diagonal: %lf\n", FirstSum);
 printf("Sum of the secondary diagonal: %lf\n\n", SecondSum);
 
 int array[N][N];

 printf("Enter the values matrix (4 integers): \n");
 for (i = 0; i < N; i++) {
  for (j = 0; j < N; j++) {
    scanf_s("%d", &array[i][j]);
  }

 }
 
 printf("Squares of 2x2 matrix elements:\n");
 for (i = 0; i < N; i++) {
  for (j = 0; j < N; j++) {
   printf("%d\t", array[i][j] * array[i][j]);
  }
  printf("\n");
 }


 return 0;
}
