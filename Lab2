#include <stdio.h>


int main(int argc, char* argv[]) {

 double arr[3][3];
 double FirstSum = 0.0;
 double SecondSum = 0.0;

 printf("Enter the elements of the 3x3 matrix (9 numbers separated by spaces): \n");
 for (int i = 0; i < 3; i++) {
  for (int j = 0; j < 3; j++) {
   scanf_s("%lf", &arr[i][j]);
  }
 }

 for (int i = 0; i < 3; i++) {

  FirstSum += arr[i][i];

  SecondSum += arr[i][2 - i];

 }
 printf("Sum of the main diagonal: %lf\n", FirstSum);
 printf("Sum of the secondary diagonal: %lf\n\n", SecondSum);

 int array[2][2];

 printf("Enter the values matrix (4 integers): \n");
 for (int i = 0; i < 2; i++) {
  for (int j = 0; j < 2; j++) {
    scanf_s("%d", &array[i][j]);
  }

 }
 
 printf("Squares of 2x2 matrix elements:\n");
 for (int i = 0; i < 2; i++) {
  for (int j = 0; j < 2; j++) {
   printf("%d\t", array[i][j] * array[i][j]);
  }
  printf("\n");
 }


 return 0;
}
